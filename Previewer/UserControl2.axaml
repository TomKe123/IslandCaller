<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ci="clr-namespace:ClassIsland.Core.Controls;assembly=ClassIsland.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Previewer.UserControl2">
  <StackPanel>
	  <ci:IconText Glyph="&#xEF27;" Text="基本设置" Margin="0,0,0,4"/>
      <!-- 下课禁用 -->
      <fa:SettingsExpander
      IconSource="{ci:FluentIconSource &#xE4CE;}"
      Header="下课禁用"
      Description="在非上课时间禁用所有点名功能">
		  <fa:SettingsExpander.Footer>
			  <ToggleSwitch/>
          </fa:SettingsExpander.Footer>
      </fa:SettingsExpander>
  </StackPanel>
</UserControl>
