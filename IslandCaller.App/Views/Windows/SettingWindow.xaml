<Window x:Class="IslandCaller.App.Views.Windows.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IslandCaller.App.Views.Windows"
        xmlns:page="clr-namespace:IslandCaller.App.Views.Pages"
        mc:Ignorable="d"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        ui:TitleBar.Height="36"
        Title="IslandCaller 设置" 
        Height="600" Width="1000"
        Icon="/IslandCaller.App;component/Resource/Icon.ico">
    <Grid>
        <ui:NavigationView
    x:Name="rootNav"
    IsTabStop="False"
    IsPaneOpen="False"
    PaneDisplayMode="Auto"
    VerticalAlignment="Stretch"
    HorizontalAlignment="Stretch"
    Height="Auto"
    IsBackButtonVisible="Collapsed"
    Loaded="OnNavigationViewLoaded"
    SelectionChanged="OnNavigationViewSelectionChanged">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="通用"
                    Tag="{x:Type page:GeneralPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Settings}"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem
                    Content="档案"
                    Tag="{x:Type page:ProfilePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Document}"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem
                    Content="悬浮窗"
                    Tag="{x:Type page:HoverPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.NewWindow}"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem
                    Content="安全"
                    Tag="{x:Type page:SecurityPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Lock}"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:Frame x:Name="rootFrame" Margin="0,0,0,0" />
        </ui:NavigationView>
    </Grid>
</Window>
