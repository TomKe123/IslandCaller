<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ci="clr-namespace:ClassIsland.Core.Controls;assembly=ClassIsland.Core"
        xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        mc:Ignorable="d"
        x:Class="IslandCaller.Views.PersonalCall"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource SurfaceStrokeColorDefaultBrush}"
        SystemDecorations="Full"
        TransparencyLevelHint="Mica"
        ShowInTaskbar="False"
        Topmost="True"
        CanResize="False"
        Height="430"
        MinHeight="430"
        Width="640"
        MinWidth="640"
        WindowStartupLocation="CenterScreen">
  <Panel Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24" Spacing="12">
      <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,4">
        <ci:FluentIcon Glyph="&#xED38;" FontSize="22" Grid.Column="0"/>
        <TextBlock Grid.Column="1"
                   Margin="6,0,0,0"
                   VerticalAlignment="Center"
                   FontFamily="HarmonyOS Sans SC"
                   FontSize="18"
                   Text="IslandCaller 自定义抽取"/>
      </Grid>

      <Border Padding="12" CornerRadius="8" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
        <TextBlock Opacity="0.78" TextWrapping="Wrap" Text="{Binding AvailabilityText}"/>
      </Border>

      <Border Padding="14" CornerRadius="10" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock FontWeight="SemiBold" Text="抽取人数"/>
              <TextBlock Opacity="0.72" Text="指定本次按顺序弹出的姓名数量"/>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Text="{Binding Num, StringFormat={}{0:F0}}"/>
          </Grid>
          <Slider Minimum="1"
                  Maximum="10"
                  TabIndex="1"
                  IsSnapToTickEnabled="True"
                  Classes="auto-tooltip"
                  TickFrequency="1"
                  Value="{Binding Num, Mode=TwoWay}"/>
          <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="{Binding SelectionSummaryText}"/>
        </StackPanel>
      </Border>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
        <Button Grid.Column="0" Click="CancelButton_Click">
          <Grid ColumnDefinitions="Auto,Auto">
            <ci:FluentIcon Glyph="&#xE671;" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" Text="取消"/>
          </Grid>
        </Button>

        <Button Grid.Column="1"
                Classes="accent"
                IsEnabled="{Binding CanStartCall}"
                Click="SureButton_Click">
          <Grid ColumnDefinitions="Auto,Auto">
            <ci:FluentIcon Glyph="&#xE423;" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" Text="开始点名"/>
          </Grid>
        </Button>
      </Grid>
      </StackPanel>
    </ScrollViewer>
  </Panel>
</Window>
