<ci2:SettingsPageBase xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ci="clr-namespace:ClassIsland.Core.Controls;assembly=ClassIsland.Core"
             xmlns:ci2="clr-namespace:ClassIsland.Core.Abstractions.Controls;assembly=ClassIsland.Core"
             xmlns:vm="using:IslandCaller.ViewModels"
             xmlns:cvt="using:IslandCaller.Converters"
             xmlns:ci3="http://classisland.tech/schemas/xaml/core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IslandCaller.Views.SettingPage">
    <ci2:SettingsPageBase.DataContext>
        <vm:SettingPageViewModel />
    </ci2:SettingsPageBase.DataContext>
    <Design.DataContext>
		<vm:SettingPageViewModel />
    </Design.DataContext>
    <ci2:SettingsPageBase.Resources>
		<cvt:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <cvt:GenderConverter x:Key="GenderConverter"/>
    </ci2:SettingsPageBase.Resources>

    <ScrollViewer>
		<StackPanel Classes="settings-container animated-intro">
        <!-- 基本设置 -->
	    <ci:IconText Glyph="&#xEF27;" Text="基本设置" Margin="0,0,0,4"/>
        <!-- 下课禁用 -->
        <fa:SettingsExpander
        IconSource="{ci:FluentIconSource &#xE4CE;}"
        Header="下课禁用"
        Description="在课间禁用所有点名功能">
		    <fa:SettingsExpander.Footer>
			    <ToggleSwitch
                IsChecked="{Binding IsBreakDisable, Mode=TwoWay}"/>
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>
        <fa:SettingsExpander
        IconSource="{ci:FluentIconSource &#xE765;}"
        Header="全局快捷键"
        Description="支持在任意界面快速点名或打开高级点名窗口">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding IsGlobalHotkeyEnabled, Mode=TwoWay}"/>
            </fa:SettingsExpander.Footer>
            <fa:SettingsExpanderItem>
                <StackPanel Spacing="8">
                    <TextBlock Text="快速点名快捷键（1人）"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center" Text="{Binding QuickCallHotkey}"/>
                        <Button Click="StartQuickHotkeyBindingButton_OnClick">开始绑定</Button>
                        <Button Click="ResetQuickHotkeyButton_OnClick">重置此项</Button>
                    </StackPanel>
                    <TextBlock Text="高级点名快捷键（打开自定义人数窗口）"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center" Text="{Binding AdvancedCallHotkey}"/>
                        <Button Click="StartAdvancedHotkeyBindingButton_OnClick">开始绑定</Button>
                        <Button Click="ResetAdvancedHotkeyButton_OnClick">重置此项</Button>
                    </StackPanel>
                    <Button HorizontalAlignment="Left" Click="ResetHotkeysButton_OnClick">重置快捷键</Button>
                    <TextBlock x:Name="HotkeyCaptureHint" Opacity="0.7" Text="按键绑定模式：点击开始绑定，可依次按下组合键完成绑定（仅禁止单独鼠标左键/鼠标右键；Esc/Backspace/Delete 清空）"/>
                </StackPanel>
            </fa:SettingsExpanderItem>
        </fa:SettingsExpander>

        <fa:SettingsExpander
        IconSource="{ci:FluentIconSource &#xE814;}"
        Header="保底机制"
        Description="对保底名单启用‘连续未被点到阈值’强制触发">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding IsGuaranteeEnabled, Mode=TwoWay}"/>
            </fa:SettingsExpander.Footer>
            <fa:SettingsExpanderItem>
                <StackPanel Spacing="8">
                    <TextBlock Text="保底阈值（连续未被点到次数）"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGuaranteeEnabled}">
                        <Slider Minimum="1" Maximum="50"
                                Width="240"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding GuaranteeThreshold, Mode=TwoWay}"/>
                        <TextBlock VerticalAlignment="Center" Text="{Binding GuaranteeThreshold}"/>
                    </StackPanel>

                    <TextBlock Text="保底名单与权重"/>
					<DataGrid
                        IsEnabled="{Binding IsGuaranteeEnabled}"
                        ItemsSource="{Binding GuaranteeWeightList}"
                        RowHeight="45">
						<DataGrid.Columns>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" IsReadOnly="True" />

                            <!-- 保底权重列，使用Slider和TextBlock显示 -->
                            <DataGridTemplateColumn Header="保底权重">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
											<Slider Minimum="0.1" Maximum="10.0"
                                                VerticalAlignment="Center"
                                                Width="160"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding Weight, Mode=TwoWay}"/>
                                            <TextBlock Text="{Binding Weight , StringFormat={}{0:F2}}" Margin="10,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 删除按钮 -->
                            <DataGridTemplateColumn>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                                Command="{Binding DataContext.RemoveGuaranteeRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Red"
                                                Margin="6,0">
                                            <ci:FluentIcon Glyph="&#xE61D;"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox Margin="5,10"
                                  Width="260"
                                  IsEnabled="{Binding IsGuaranteeEnabled}"
                                  ItemsSource="{Binding GuaranteeMemberOptions}"
                                  SelectedItem="{Binding SelectedGuaranteeMember, Mode=TwoWay}"/>
						<Button Margin="5,10" IsEnabled="{Binding IsGuaranteeEnabled}" Click="AddGuaranteeMemberButton_OnClick">
							<ci:IconText Glyph="&#xE00D;" Text="添加保底成员"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Opacity="0.78" TextWrapping="Wrap" Margin="5,0,0,10" Text="{Binding GuaranteeSummaryText}"/>
                </StackPanel>
            </fa:SettingsExpanderItem>
        </fa:SettingsExpander>

        <fa:SettingsExpander
        IconSource="{ci:FluentIconSource &#xE823;}"
        Header="历史记录与统计"
        Description="查看每位成员的历史次数、本节状态和汇总统计">
            <fa:SettingsExpanderItem>
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="RefreshHistoryStatsButton_OnClick">刷新历史和统计</Button>
                        <Button Click="ClearButton_OnClick">清空全部历史</Button>
                    </StackPanel>
                    <TextBlock Text="统计概览" FontWeight="SemiBold"/>
                    <DataGrid ItemsSource="{Binding StatisticsList}"
                              RowHeight="36"
                              MaxHeight="220"
                              CanUserSortColumns="False"
                              CanUserResizeColumns="True"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="指标" Binding="{Binding Metric}" Width="2*" />
                            <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="最近20次点名（新 -&gt; 旧）" FontWeight="SemiBold"/>
                    <DataGrid ItemsSource="{Binding RecentCallList}"
                              RowHeight="34"
                              MaxHeight="220"
                              CanUserSortColumns="False"
                              CanUserResizeColumns="True"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="90" />
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="历史明细" FontWeight="SemiBold"/>
                    <DataGrid ItemsSource="{Binding HistoryList}"
                              RowHeight="36"
                              MinHeight="180"
                              MaxHeight="340"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="历史次数" Binding="{Binding LongTermCount}" Width="120" />
                            <DataGridTextColumn Header="连续未点次数" Binding="{Binding SessionMissCount}" Width="140" />
                            <DataGridTextColumn Header="本节最近序号" Binding="{Binding LastCallText}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </fa:SettingsExpanderItem>
        </fa:SettingsExpander>

        <!-- 悬浮窗设置 -->
        <Separator Margin="0 12 0 4" />
        <ci:IconText Glyph="&#xF485;" Text="悬浮窗设置" Margin="0,0,0,4"/>
        <!-- 启用悬浮窗 -->
        <fa:SettingsExpander
        IconSource="{ci:FluentIconSource &#xF485;}"
        Header="启用悬浮窗"
        Description="是否显示点名悬浮窗">
            <fa:SettingsExpander.Footer>
				<ToggleSwitch 
                IsChecked="{Binding IsHoverEnable, Mode=TwoWay}"/>
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>
        <!-- 悬浮窗缩放系数 -->
        <fa:SettingsExpander
        IconSource="{ci:FluentIconSource &#xE10F;}"
        Header="悬浮窗缩放系数"
        Description="调整悬浮窗大小，以适配不同的屏幕">
            <fa:SettingsExpander.Footer>
				<Slider Minimum="0.5" Maximum="2"
                        VerticalAlignment="Center"
                        TickFrequency="0.05"
                        Width="180"
                        IsSnapToTickEnabled="True"
                        Classes="auto-tooltip"
                        ci3:SliderDragTooltipAssist.StringFormat="F2"
                        Value="{Binding HoverScalingFactor, Mode=TwoWay}"/>
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>
        <!-- 档案设置 -->
        <Separator Margin="0 12 0 4" />
        <ci:IconText Glyph="&#xF1F4;" Text="档案设置" Margin="0,0,0,4"/>
        <fa:SettingsExpander
            IconSource="{ci:FluentIconSource &#xF20C;}"
            Header="档案编辑"
            Description="编辑点名时使用的名单">
            <fa:SettingsExpanderItem>
				<StackPanel>
					<DataGrid
                        ItemsSource="{Binding ProfileList}"
                        RowHeight="45">
						<DataGrid.Columns>
							<DataGridTextColumn Header="序号" Binding="{Binding ID}" />
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" />
                            <DataGridTemplateColumn Header="性别">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton IsChecked="{Binding Gender, Mode=TwoWay, Converter={StaticResource IntToBoolConverter}}"
                                                      Content="{Binding Gender, Converter={StaticResource GenderConverter}}">
                                        </ToggleButton>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 手动权重列，使用Slider和TextBlock显示 -->
                            <DataGridTemplateColumn Header="手动权重">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
											<Slider Minimum="0" Maximum="10.0"
                                                VerticalAlignment="Center"
                                                Width="160"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding ManualWeight, Mode=TwoWay}"/>
                                            <TextBlock Text="{Binding ManualWeight , StringFormat={}{0:F2}}" Margin="10,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 删除按钮 -->
                            <DataGridTemplateColumn>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                                Command="{Binding DataContext.RowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Red"
                                                Margin="6,0">
                                            <ci:FluentIcon Glyph="&#xE61D;"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal">
						<Button Margin="5,10" Click="AddButton_OnClick">
							<ci:IconText Glyph="&#xE00D;" Text="添加人员"/>
                        </Button>
                        <Button Margin="5,10" Click="ImportButton_OnClick">
							<ci:IconText Glyph="&#xE58F;" Text="导入名单"/>
                        </Button>
                        <Button Margin="5,10" Click="ClearButton_OnClick">
							<ci:IconText Glyph="&#xE2C2;" Text="清除历史记录"/>
                        </Button>
                        <Button Margin="5,10" Click="RefreshHistoryStatsButton_OnClick">
							<ci:IconText Glyph="&#xE81C;" Text="刷新统计"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </fa:SettingsExpanderItem>
        </fa:SettingsExpander>
  </StackPanel>
    </ScrollViewer>
</ci2:SettingsPageBase>
