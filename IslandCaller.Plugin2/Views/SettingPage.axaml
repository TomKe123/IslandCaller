<ci2:SettingsPageBase xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ci="clr-namespace:ClassIsland.Core.Controls;assembly=ClassIsland.Core"
             xmlns:ci2="clr-namespace:ClassIsland.Core.Abstractions.Controls;assembly=ClassIsland.Core"
             xmlns:vm="using:IslandCaller.ViewModels"
             xmlns:cvt="using:IslandCaller.Converters"
             xmlns:ci3="http://classisland.tech/schemas/xaml/core"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="720"
             x:Class="IslandCaller.Views.SettingPage">
    <ci2:SettingsPageBase.DataContext>
        <vm:SettingPageViewModel />
    </ci2:SettingsPageBase.DataContext>
    <Design.DataContext>
        <vm:SettingPageViewModel />
    </Design.DataContext>
    <ci2:SettingsPageBase.Resources>
        <cvt:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <cvt:GenderConverter x:Key="GenderConverter"/>
    </ci2:SettingsPageBase.Resources>

    <ScrollViewer>
        <StackPanel Classes="settings-container animated-intro" Spacing="10">
            <Border Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    IsVisible="{Binding IsProtectedSettingsLocked}">
                <TextBlock FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Text="{Binding ProtectedSettingsLockText}"/>
            </Border>

            <ci:IconText Glyph="&#xE72E;" Text="安全设置" Margin="0,0,0,4"/>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE72E;}" Header="U盘验证" Description="写入并验证授权U盘">
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="8">
                        <Border Padding="14"
                                CornerRadius="10"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="状态总览"/>
                                <TextBlock FontWeight="SemiBold" Text="{Binding UsbAuthStatusSummary}"/>
                                <TextBlock Opacity="0.78" TextWrapping="Wrap" Text="{Binding UsbAuthStatusText}"/>
                                <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="{Binding UsbAuthActionMessage}"/>
                            </StackPanel>
                        </Border>

                        <Border Padding="14"
                                CornerRadius="10"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="签发向导"/>
                                <TextBlock Opacity="0.78" TextWrapping="Wrap" Text="{Binding UsbAuthGuideText}"/>

                                <TextBlock Text="授权文件名"/>
                                <TextBox Width="280"
                                         IsEnabled="{Binding CanModifyUsbAuthConfiguration}"
                                         Text="{Binding AuthFileName, Mode=TwoWay}"
                                         Watermark="IslandCaller.auth"/>

                                <TextBlock Text="当前公钥指纹"/>
                                <TextBox Width="240"
                                         IsReadOnly="True"
                                         Text="{Binding KeyFingerprint}"
                                         Watermark="首次写入时自动生成"/>

                                <TextBlock Text="已检测到的U盘"/>
                                <ComboBox Width="360"
                                          ItemsSource="{Binding RemovableDrives}"
                                          SelectedItem="{Binding SelectedDrive, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"/>
                                                <TextBlock Opacity="0.65" Text="{Binding StateText}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="{Binding SelectedDriveHint}"/>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding RefreshUsbDrivesCommand}">刷新U盘列表</Button>
                                    <Button Command="{Binding WriteAuthorizationFileCommand}"
                                            Content="{Binding WriteButtonText}"
                                            IsEnabled="{Binding CanWriteAuthorization}"/>
                                    <Button Command="{Binding DisableUsbAuthCommand}"
                                            IsEnabled="{Binding CanDisableProtection}">关闭U盘验证</Button>
                                    <Button Command="{Binding RegenerateKeyPairCommand}"
                                            IsEnabled="{Binding CanRegenerateKeyPair}">重置密钥对</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>

            <StackPanel Spacing="10">
            <ci:IconText Glyph="&#xEF27;" Text="基本设置" Margin="0,0,0,4"/>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE4CE;}" Header="下课禁用" Description="课间禁用点名">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding IsBreakDisable, Mode=TwoWay}"
                                  IsEnabled="{Binding CanEditProtectedSettings}"/>
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE8D4;}" Header="默认抽选模式" Description="设置全局默认的抽选范围和算法">
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="10" IsEnabled="{Binding CanEditProtectedSettings}">
                        <TextBlock Opacity="0.78"
                                   TextWrapping="Wrap"
                                   Text="自定义点名窗口可临时覆盖本节课模式；到下一节课会自动恢复到这里的默认设置。"/>
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="默认范围"/>
                            <ComboBox Grid.Row="0"
                                      Grid.Column="1"
                                      ItemsSource="{Binding DrawScopeOptions}"
                                      DisplayMemberBinding="{Binding Label}"
                                      SelectedItem="{Binding SelectedDrawScopeOption, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="默认算法"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      ItemsSource="{Binding DrawAlgorithmOptions}"
                                      DisplayMemberBinding="{Binding Label}"
                                      SelectedItem="{Binding SelectedDrawAlgorithmOption, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE765;}" Header="全局快捷键" Description="设置快速操作快捷键">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding IsGlobalHotkeyEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding CanEditProtectedSettings}"/>
                </fa:SettingsExpander.Footer>
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="8" IsEnabled="{Binding CanEditProtectedSettings}">
                        <TextBlock Text="快速点名快捷键"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock VerticalAlignment="Center" Text="{Binding QuickCallHotkey}"/>
                            <Button Click="StartQuickHotkeyBindingButton_OnClick">开始绑定</Button>
                            <Button Click="ResetQuickHotkeyButton_OnClick">重置此项</Button>
                        </StackPanel>
                        <TextBlock Text="高级点名快捷键"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock VerticalAlignment="Center" Text="{Binding AdvancedCallHotkey}"/>
                            <Button Click="StartAdvancedHotkeyBindingButton_OnClick">开始绑定</Button>
                            <Button Click="ResetAdvancedHotkeyButton_OnClick">重置此项</Button>
                        </StackPanel>
                        <Button HorizontalAlignment="Left" Click="ResetHotkeysButton_OnClick">重置全部快捷键</Button>
                        <TextBlock x:Name="HotkeyCaptureHint" Opacity="0.7" Text="点击“开始绑定”后按下组合键。Esc/Backspace/Delete 可清空。"/>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE7BF;}" Header="抽奖设置" Description="设置奖项和抽取人数">
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="8" IsEnabled="{Binding CanEditProtectedSettings}">
                        <TextBlock Opacity="0.78" TextWrapping="Wrap" Text="{Binding LotterySummaryText}"/>
                        <DataGrid ItemsSource="{Binding LotteryPrizeList}" RowHeight="40" MaxHeight="240">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="奖项" Binding="{Binding Name, Mode=TwoWay}" Width="*"/>
                                <DataGridTextColumn Header="人数" Binding="{Binding WinnerCount, Mode=TwoWay}" Width="120"/>
                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveLotteryPrizeRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Red"
                                                    Margin="6,0">
                                                <ci:FluentIcon Glyph="&#xE61D;"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding AddLotteryPrizeCommand}">
                                <ci:IconText Glyph="&#xE00D;" Text="添加奖项"/>
                            </Button>
                            <Button Command="{Binding OpenLotteryWindowCommand}">
                                <ci:IconText Glyph="&#xE7C5;" Text="打开抽奖窗口"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Opacity="0.72"
                                   TextWrapping="Wrap"
                                   Text="URI：Lottery/GUI 或 Lottery/Draw?prize=一等奖&amp;count=1"/>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE8A5;}" Header="保底模式" Description="启用保底抽选">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding IsGachaEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding CanEditProtectedSettings}"/>
                </fa:SettingsExpander.Footer>
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="8" IsEnabled="{Binding CanEditProtectedSettings}">
                        <TextBlock Opacity="0.78" TextWrapping="Wrap" Text="{Binding GachaSummaryText}"/>
                        <Separator Margin="0,4,0,2"/>

                        <TextBlock Opacity="0.72"
                                   TextWrapping="Wrap"
                                   Text="启用U盘验证后，插入授权U盘才可修改下方配置。"/>

                        <TextBlock Text="五星候选配置"/>
                        <DataGrid ItemsSource="{Binding ProfileList}" RowHeight="40" MaxHeight="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
                                <DataGridTemplateColumn Header="星级" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.RarityOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                      SelectedItem="{Binding Rarity, Mode=TwoWay}"
                                                      IsEnabled="{Binding DataContext.IsGachaEnabled, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="星级设为 5 即加入五星候选。系统每天随机 1 名五星 UP，并从其余成员中随机 3 名四星 UP。"/>

                        <TextBlock Text="五星基础概率"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGachaEnabled}">
                            <Slider Minimum="0.001" Maximum="0.05" Width="240" TickFrequency="0.001" Value="{Binding FiveStarBaseRate, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FiveStarBaseRate, StringFormat={}{0:P2}}"/>
                        </StackPanel>

                        <TextBlock Text="五星软保底起点 / 硬保底"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGachaEnabled}">
                            <Slider Minimum="1" Maximum="89" Width="180" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding FiveStarSoftPityStart, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FiveStarSoftPityStart}"/>
                            <Slider Minimum="1" Maximum="120" Width="180" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding FiveStarHardPity, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FiveStarHardPity}"/>
                        </StackPanel>

                        <TextBlock Text="四星基础概率"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGachaEnabled}">
                            <Slider Minimum="0.01" Maximum="0.3" Width="240" TickFrequency="0.005" Value="{Binding FourStarBaseRate, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FourStarBaseRate, StringFormat={}{0:P2}}"/>
                        </StackPanel>

                        <TextBlock Text="四星软保底起点 / 硬保底"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGachaEnabled}">
                            <Slider Minimum="1" Maximum="9" Width="180" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding FourStarSoftPityStart, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FourStarSoftPityStart}"/>
                            <Slider Minimum="1" Maximum="20" Width="180" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding FourStarHardPity, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FourStarHardPity}"/>
                        </StackPanel>

                        <TextBlock Text="五星 UP 概率 / 四星 UP 概率"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding IsGachaEnabled}">
                            <Slider Minimum="0" Maximum="1" Width="180" TickFrequency="0.05" Value="{Binding FiveStarFeaturedRate, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FiveStarFeaturedRate, StringFormat={}{0:P0}}"/>
                            <Slider Minimum="0" Maximum="1" Width="180" TickFrequency="0.05" Value="{Binding FourStarFeaturedRate, Mode=TwoWay}"/>
                            <TextBlock VerticalAlignment="Center" Text="{Binding FourStarFeaturedRate, StringFormat={}{0:P0}}"/>
                        </StackPanel>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE823;}" Header="历史记录与统计" Description="查看历史和保底状态">
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="8" IsEnabled="{Binding CanEditProtectedSettings}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="RefreshHistoryStatsButton_OnClick">刷新历史和统计</Button>
                            <Button Click="ExportHistoryButton_OnClick"
                                    ToolTip.Tip="导出全部点名记录为 .xlsx，直到清空点名历史前都会持续累计。">导出点名记录.xlsx</Button>
                            <Button Click="ClearButton_OnClick"
                                    ToolTip.Tip="会同时清空本节历史、长期统计、全部点名记录和保底水位。">清空点名历史</Button>
                        </StackPanel>
                        <TextBlock Text="统计概览" FontWeight="SemiBold"/>
                        <DataGrid ItemsSource="{Binding StatisticsList}" RowHeight="36" MaxHeight="260" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="指标" Binding="{Binding Metric}" Width="2*"/>
                                <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="最近 20 次点名" FontWeight="SemiBold"/>
                        <DataGrid ItemsSource="{Binding RecentCallList}" RowHeight="34" MaxHeight="220" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="90"/>
                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="历史明细" FontWeight="SemiBold"/>
                        <DataGrid ItemsSource="{Binding HistoryList}" RowHeight="36" MinHeight="180" MaxHeight="340" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="历史次数" Binding="{Binding LongTermCount}" Width="120"/>
                                <DataGridTextColumn Header="连续未点次数" Binding="{Binding SessionMissCount}" Width="140"/>
                                <DataGridTextColumn Header="本节最近序号" Binding="{Binding LastCallText}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>

            <Separator Margin="0 12 0 4"/>
            <ci:IconText Glyph="&#xF485;" Text="悬浮窗设置" Margin="0,0,0,4"/>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF485;}" Header="启用悬浮窗" Description="显示悬浮窗">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding IsHoverEnable, Mode=TwoWay}"
                                  IsEnabled="{Binding CanEditProtectedSettings}"/>
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE10F;}" Header="悬浮窗缩放系数" Description="调整悬浮窗大小">
                <fa:SettingsExpander.Footer>
                    <Slider Minimum="0.5" Maximum="2"
                            Width="180"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            IsEnabled="{Binding CanEditProtectedSettings}"
                            Classes="auto-tooltip"
                            ci3:SliderDragTooltipAssist.StringFormat="F2"
                            Value="{Binding HoverScalingFactor, Mode=TwoWay}"/>
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <Separator Margin="0 12 0 4"/>
            <ci:IconText Glyph="&#xF1F4;" Text="档案设置" Margin="0,0,0,4"/>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF20C;}" Header="档案编辑" Description="编辑成员和权重">
                <fa:SettingsExpanderItem>
                    <StackPanel Spacing="8" IsEnabled="{Binding CanEditProtectedSettings}">
                        <Border Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <TextBlock Opacity="0.78"
                                       TextWrapping="Wrap"
                                       Text="{Binding ProfileSummaryText}"/>
                        </Border>
                        <DataGrid ItemsSource="{Binding ProfileList}" RowHeight="45">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding ID}" Width="80"/>
                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                                <DataGridTemplateColumn Header="性别" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ToggleButton IsChecked="{Binding Gender, Mode=TwoWay, Converter={StaticResource IntToBoolConverter}}"
                                                          Content="{Binding Gender, Converter={StaticResource GenderConverter}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="手动权重" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider Minimum="0" Maximum="10.0" Width="160" TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding ManualWeight, Mode=TwoWay}"/>
                                                <TextBlock Text="{Binding ManualWeight, StringFormat={}{0:F2}}" Margin="10,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Red"
                                                    Margin="6,0">
                                                <ci:FluentIcon Glyph="&#xE61D;"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="AddButton_OnClick">
                                <ci:IconText Glyph="&#xE00D;" Text="添加成员"/>
                            </Button>
                            <Button Click="ImportButton_OnClick">
                                <ci:IconText Glyph="&#xE58F;" Text="导入名单"/>
                            </Button>
                            <Button Click="ClearButton_OnClick"
                                    ToolTip.Tip="会同时清空本节历史、长期统计和保底水位。">
                                <ci:IconText Glyph="&#xE2C2;" Text="清空点名历史"/>
                            </Button>
                            <Button Click="RefreshHistoryStatsButton_OnClick">
                                <ci:IconText Glyph="&#xE81C;" Text="刷新统计"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </fa:SettingsExpanderItem>
            </fa:SettingsExpander>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ci2:SettingsPageBase>
